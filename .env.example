# ===========================================
# DatepalmBay Official API Server - Environment Variables
# ===========================================

# Server Configuration
PORT=8080
NODE_ENV=development

# ===========================================
# YouTube Data API v3
# ===========================================
# Get your API key from: https://console.cloud.google.com/
# Enable "YouTube Data API v3" in your Google Cloud project
YOUTUBE_API_KEY=your_youtube_api_key_here

# ===========================================
# TikTok API v2 (Optional)
# ===========================================
# Required for collecting TikTok reviews
#
# Setup Guide:
# 1. Create a TikTok Developer account: https://developers.tiktok.com/
# 2. Create an app in the TikTok Developer Portal
# 3. Enable "Video API" product for your app
# 4. Select "video.list" scope
# 5. Get your Client Key and Client Secret from "App Key" menu
#
# Docs: https://developers.tiktok.com/doc/tiktok-api-v2-video-query

# Your TikTok App Client Key
TIKTOK_CLIENT_KEY=

# Your TikTok App Client Secret
TIKTOK_CLIENT_SECRET=

# ===========================================
# Twilio Verify API (SMS + Email 인증)
# ===========================================
# 1. Sign up at twilio.com
# 2. Get Account SID and Auth Token from Console Dashboard
# 3. Create Verify Service: Console → Verify → Create Service
# 4. Copy Service SID (starts with VA...)
# 5. Email 인증 활성화: Verify Service Settings → Email Integration 설정
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VA...

# ===========================================
# Claude AI (Anthropic) - Review Analysis
# ===========================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_PROVIDER=claude
AI_MODEL=claude-haiku-4-5-20251001

# ===========================================
# FedEx REST API (물류 연동)
# ===========================================
# 1. Sign up at developer.fedex.com
# 2. Create a project and get API Key + Secret Key
# 3. Get your FedEx Account Number from your FedEx account
# Docs: https://developer.fedex.com/api/en-us/home.html
FEDEX_API_KEY=your_fedex_api_key_here
FEDEX_SECRET_KEY=your_fedex_secret_key_here
FEDEX_ACCOUNT_NUMBER=your_fedex_account_number_here
FEDEX_MODE=sandbox
# Shipper info (warehouse/origin address)
FEDEX_SHIPPER_NAME=Datepalm Bay
FEDEX_SHIPPER_COMPANY=Datepalm Bay Co.
FEDEX_SHIPPER_PHONE=+821012345678
FEDEX_SHIPPER_STREET=123 Warehouse Street
FEDEX_SHIPPER_CITY=Seoul
FEDEX_SHIPPER_STATE=Seoul
FEDEX_SHIPPER_POSTAL=04524
FEDEX_SHIPPER_COUNTRY=KR

# ===========================================
# Aramex API (MENA 물류 연동)
# ===========================================
# 1. Register at aramex.com/developer
# 2. Get your account credentials from your Aramex account manager
# 3. AccountEntity: 3-letter Aramex station code (e.g. DXB for Dubai)
# Docs: https://ws.aramex.net/ShippingAPI.V2
ARAMEX_USERNAME=your_aramex_username_here
ARAMEX_PASSWORD=your_aramex_password_here
ARAMEX_ACCOUNT_NUMBER=your_aramex_account_number_here
ARAMEX_ACCOUNT_PIN=your_aramex_account_pin_here
ARAMEX_ACCOUNT_ENTITY=DXB
ARAMEX_ACCOUNT_COUNTRY_CODE=AE
ARAMEX_MODE=test
# Shipper info (warehouse/origin address)
ARAMEX_SHIPPER_NAME=Datepalm Bay
ARAMEX_SHIPPER_COMPANY=Datepalm Bay Co.
ARAMEX_SHIPPER_PHONE=+821012345678
ARAMEX_SHIPPER_STREET=123 Warehouse Street
ARAMEX_SHIPPER_CITY=Seoul
ARAMEX_SHIPPER_COUNTRY=KR

